# ── Blockchain Configuration ─────────────────────────────────────────────
# Local Hardhat node (default for development)
RPC_URL=http://127.0.0.1:8545

# Testnet - Ethereum Sepolia
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Testnet - Polygon Mumbai
MUMBAI_RPC_URL=https://polygon-mumbai.infura.io/v3/YOUR_INFURA_KEY

# Deployer private key (NEVER commit for mainnet!)
# Use a test account key for development
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Etherscan verification (optional)
ETHERSCAN_API_KEY=

# ── Database Configuration ───────────────────────────────────────────────
# Local MongoDB (default)
MONGODB_URI=mongodb://localhost:27017/chainfund

# Or use MongoDB Atlas cloud:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chainfund?retryWrites=true&w=majority

# ── Authentication ───────────────────────────────────────────────────────
# JWT secret for signing auth tokens (change to a random 32+ char string in production!)
JWT_SECRET=change_this_to_a_random_secret_in_production_at_least_32_chars

# ── Server Configuration ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Exchange Rates ───────────────────────────────────────────────────────
# ETH to INR conversion rate (update manually or integrate Chainlink oracle)
ETH_INR_RATE=220000
